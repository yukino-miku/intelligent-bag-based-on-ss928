{
  "paths": {
    "python": "/root/smartbag/venv/bin/python",
    "vision": "/root/smartbag/vision",
    "model": "/root/smartbag/models/yolo11n.pt"
  },
  "controller_status_file": "/run/smartbag/controller-status.json",
  "controller_event_jsonl": "/var/log/smartbag/controller-events.jsonl",
  "controller_actuator_jsonl": "/var/log/smartbag/actuator-events.jsonl",
  "hardware_profile_file": "/etc/smartbag/hardware.json",
  "detector_restart": {
    "limit": 5,
    "backoff_s": 1.0
  },
  "vision_runtime": {
    "mode": "alternating_single_model"
  },
  "alternating_camera": {
    "enabled": true,
    "backend": "v4l2_stream_toggle",
    "width": 640,
    "height": 480,
    "fps": 30,
    "imgsz": 416,
    "conf": 0.08,
    "max_det": 30,
    "normal_slice_ms": 500,
    "risk_slice_ms": 700,
    "minimum_other_side_slice_ms": 250,
    "warmup_frames": 2,
    "frames_per_slice": 4,
    "inference_frames_per_slice": 1,
    "max_blind_interval_ms": 1200,
    "stale_observation_timeout_ms": 1800,
    "switch_failure_limit": 3,
    "switch_backoff_ms": 200,
    "camera_reconnect_enabled": true,
    "camera_reconnect_attempts": 5,
    "camera_reconnect_initial_backoff_s": 0.5,
    "camera_reconnect_max_backoff_s": 8.0,
    "tracker_reset_after_disconnect_s": 3.0,
    "tracker_nominal_fps": 10,
    "tracker_effective_fps_mode": "effective_side",
    "min_confirm_slices_caution": 2,
    "min_confirm_slices_danger": 2,
    "min_confirm_slices_emergency": 2,
    "minimum_confirmation_interval_s": 0.2,
    "allow_emergency_single_slice_fast_path": true,
    "risk_priority_enabled": true,
    "prefer_openvino": false,
    "video_gateway_enabled": true,
    "serve_bind": "0.0.0.0",
    "serve_port": 8080,
    "access_token": "",
    "jpeg_quality": 80,
    "overlay_width": 0,
    "overlay_height": 0,
    "stream_fps_limit": 5,
    "calibration_mode": "diagnostic",
    "output_dir": "/var/log/smartbag/alternating-camera-runs",
    "risk_log_dir": "/var/log/smartbag"
  },
  "cameras": {
    "left": {
      "camera_device": "/dev/v4l/by-path/platform-10320000.xhci_1-usb-0:1.3:1.0-video-index0",
      "detector_profile": "board_dual_balanced",
      "calibration_file": "/etc/smartbag/calibration-left.json",
      "camera_height": 1.2,
      "camera_pitch": 5.0,
      "camera_fps": 30,
      "inference_fps_limit": 8,
      "process_every_n": 1,
      "camera_reconnect_attempts": 5,
      "camera_reconnect_backoff_s": 0.5,
      "alert_min_level": 1,
      "alert_rate_limit_s": 0.25,
      "jpeg_stream_width": 480,
      "jpeg_stream_height": 360,
      "jpeg_quality": 70,
      "stream_fps_limit": 8,
      "stream_port": 18081,
      "risk_log_csv": "/var/log/smartbag/risk-left.csv",
      "pwm_channels": ["left_1", "left_2"]
    },
    "right": {
      "camera_device": "/dev/v4l/by-path/platform-10320000.xhci_1-usb-0:1.4:1.0-video-index0",
      "detector_profile": "board_dual_balanced",
      "calibration_file": "/etc/smartbag/calibration-right.json",
      "camera_height": 1.2,
      "camera_pitch": 5.0,
      "camera_fps": 30,
      "inference_fps_limit": 8,
      "process_every_n": 1,
      "camera_reconnect_attempts": 5,
      "camera_reconnect_backoff_s": 0.5,
      "alert_min_level": 1,
      "alert_rate_limit_s": 0.25,
      "jpeg_stream_width": 480,
      "jpeg_stream_height": 360,
      "jpeg_quality": 70,
      "stream_fps_limit": 8,
      "stream_port": 18082,
      "risk_log_csv": "/var/log/smartbag/risk-right.csv",
      "pwm_channels": ["right_1", "right_2"]
    }
  },
  "stream_gateway": {
    "bind": "0.0.0.0",
    "port": 8080,
    "access_token": ""
  },
  "pwm": {
    "period_ns": 1000000,
    "level_duty_percent": {
      "0": [0, 0],
      "1": [60, 0],
      "2": [60, 60],
      "3": [100, 60],
      "4": [100, 100]
    }
  },
  "timing": {
    "event_timeout_s": 2.5,
    "max_event_age_s": 2.0
  },
  "audio": {
    "enabled": true,
    "root": "/root/smartbag/audio"
  },
  "ble": {
    "name": "SS928-SmartBag"
  },
  "logging": {
    "risk_csv_enabled": false,
    "performance_enabled": true,
    "max_session_size_mb": 100,
    "max_session_count": 10,
    "risk_sample_every_n": 1,
    "rotate_count": 3
  }
}
